# All values must be provided - no defaults. Use Bitwarden or .env for local dev.
# See .github/BITWARDEN_SETUP.md for CI setup.

# Application Settings
APP_NAME=
APP_VERSION=
BASE_URL=
SUPPORT_EMAIL=
ENVIRONMENT=
DEBUG=
LOG_LEVEL=

# Server Configuration
HOST=
PORT=
WORKERS=

# PostgreSQL Configuration
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_POOL_SIZE=
POSTGRES_MAX_OVERFLOW=

# Redis Configuration
REDIS_HOST=
REDIS_PORT=
